//@version=6
indicator("GEX Daily Levels", overlay = true, max_lines_count = 64, max_labels_count = 64)

// ============================================================================
// GEX Daily Levels
// Plots externally computed dealer gamma exposure (GEX) levels from a compact
// text string. Format: price,label,kind;price,label,kind;...
// kinds: res/sup (Call/Put Wall) . res0/sup0 (0DTE walls) . flip (Gamma Flip)
//        emh/eml (ATM straddle Expected Move) . emb (fractional EM bands)
//        ivh/ivl (IV-based 1D range) . mpain (Max Pain) . gpos/gneg (top gamma)
//        opo/opu/opd (Daily Open anchor and +/- percent grid from the open)
// Levels can come from any gamma data source or your own option-chain math.
// ============================================================================

const string TIP = "Format: price,label,kind;price,label,kind;... See the script description for the full format specification and kind codes."
string market = input.string("Auto", "Market", options = ["Auto", "NQ", "ES", "SPX"], tooltip = "Auto picks the right levels string from the chart symbol (NQ/MNQ/NDX -> NQ, ES/MES -> ES, SPX/SP500 -> SPX). Force a market if needed.")
string srcNQ  = input.text_area(defval = "", title = "NQ — levels string",  tooltip = TIP)
string srcES  = input.text_area(defval = "", title = "ES — levels string",  tooltip = TIP)
string srcSPX = input.text_area(defval = "", title = "SPX — levels string", tooltip = TIP)

f_market() =>
    string m = market
    if m == "Auto"
        string sym = str.upper(syminfo.root + " " + syminfo.ticker)
        m := str.contains(sym, "NQ") or str.contains(sym, "NDX") or str.contains(sym, "US100") or str.contains(sym, "USTEC") ? "NQ" : str.contains(sym, "SPX") or str.contains(sym, "SP500") ? "SPX" : str.contains(sym, "ES") or str.contains(sym, "US500") ? "ES" : "NQ"
    m

string src = f_market() == "ES" ? srcES : f_market() == "SPX" ? srcSPX : srcNQ

// ---- global ----------------------------------------------------------------
const string GG = "Global"
bool   gShowLbl = input.bool(true, "Labels", group = GG, inline = "g1")
string gSize    = input.string("Tiny", "", options = ["Tiny", "Small", "Normal"], group = GG, inline = "g1")
int    gOff     = input.int(8, "Décalage (barres)", minval = 0, maxval = 200, group = GG, inline = "g1")
bool   gPrice   = input.bool(true, "Prix dans le label", group = GG, inline = "g2")

// ---- par famille: [visible] [couleur] [épaisseur] [style] -------------------
const string GN = "Niveaux"
const string SOL = "Solide", DSH = "Tirets", DOT = "Points"

bool   shRes = input.bool(true, "Call Wall      ", group = GN, inline = "res")
color  cRes  = input.color(#26A69A, "", group = GN, inline = "res")
int    wRes  = input.int(1, "", minval = 1, maxval = 5, group = GN, inline = "res")
string sRes  = input.string(SOL, "", options = [SOL, DSH, DOT], group = GN, inline = "res")
bool   shRes0 = input.bool(true, "Call Wall 0DTE ", group = GN, inline = "res0")
color  cRes0  = input.color(#26A69A, "", group = GN, inline = "res0")
int    wRes0  = input.int(1, "", minval = 1, maxval = 5, group = GN, inline = "res0")
string sRes0  = input.string(DSH, "", options = [SOL, DSH, DOT], group = GN, inline = "res0")
bool   shSup = input.bool(true, "Put Wall       ", group = GN, inline = "sup")
color  cSup  = input.color(#EF5350, "", group = GN, inline = "sup")
int    wSup  = input.int(1, "", minval = 1, maxval = 5, group = GN, inline = "sup")
string sSup  = input.string(SOL, "", options = [SOL, DSH, DOT], group = GN, inline = "sup")
bool   shSup0 = input.bool(true, "Put Wall 0DTE  ", group = GN, inline = "sup0")
color  cSup0  = input.color(#EF5350, "", group = GN, inline = "sup0")
int    wSup0  = input.int(1, "", minval = 1, maxval = 5, group = GN, inline = "sup0")
string sSup0  = input.string(DSH, "", options = [SOL, DSH, DOT], group = GN, inline = "sup0")
bool   shFlip = input.bool(true, "Gamma Flip     ", group = GN, inline = "flip")
color  cFlip  = input.color(#F0B90B, "", group = GN, inline = "flip")
int    wFlip  = input.int(1, "", minval = 1, maxval = 5, group = GN, inline = "flip")
string sFlip  = input.string(DSH, "", options = [SOL, DSH, DOT], group = GN, inline = "flip")
bool   shEM = input.bool(true, "Expected Move  ", group = GN, inline = "em")
color  cEM  = input.color(#E8E6E1, "", group = GN, inline = "em")
int    wEM  = input.int(1, "", minval = 1, maxval = 5, group = GN, inline = "em")
string sEM  = input.string(DOT, "", options = [SOL, DSH, DOT], group = GN, inline = "em")
bool   shEMB = input.bool(true, "EM Bands ±x%   ", group = GN, inline = "emb")
color  cEMB  = input.color(#E8E6E180, "", group = GN, inline = "emb")
int    wEMB  = input.int(1, "", minval = 1, maxval = 5, group = GN, inline = "emb")
string sEMB  = input.string(DOT, "", options = [SOL, DSH, DOT], group = GN, inline = "emb")
bool   shIV = input.bool(true, "1D Min/Max (IV)", group = GN, inline = "iv")
color  cIV  = input.color(#7A7A85, "", group = GN, inline = "iv")
int    wIV  = input.int(1, "", minval = 1, maxval = 5, group = GN, inline = "iv")
string sIV  = input.string(DOT, "", options = [SOL, DSH, DOT], group = GN, inline = "iv")
bool   shMP = input.bool(true, "Max Pain       ", group = GN, inline = "mp")
color  cMP  = input.color(#F0B90B80, "", group = GN, inline = "mp")
int    wMP  = input.int(1, "", minval = 1, maxval = 5, group = GN, inline = "mp")
string sMP  = input.string(DOT, "", options = [SOL, DSH, DOT], group = GN, inline = "mp")
bool   shGp = input.bool(true, "G+ (top gamma) ", group = GN, inline = "gp")
color  cGp  = input.color(#26A69A80, "", group = GN, inline = "gp")
int    wGp  = input.int(1, "", minval = 1, maxval = 5, group = GN, inline = "gp")
string sGp  = input.string(SOL, "", options = [SOL, DSH, DOT], group = GN, inline = "gp")
bool   shOPG = input.bool(true, "Open % grid    ", group = GN, inline = "opg")
color  cOPG  = input.color(#F0B90B, "", group = GN, inline = "opg")
int    wOPG  = input.int(1, "", minval = 1, maxval = 5, group = GN, inline = "opg")
string sOPG  = input.string(DOT, "", options = [SOL, DSH, DOT], group = GN, inline = "opg")
bool   shGn = input.bool(true, "G- (top gamma) ", group = GN, inline = "gn")
color  cGn  = input.color(#EF535080, "", group = GN, inline = "gn")
int    wGn  = input.int(1, "", minval = 1, maxval = 5, group = GN, inline = "gn")
string sGn  = input.string(SOL, "", options = [SOL, DSH, DOT], group = GN, inline = "gn")

// ---- lookups -----------------------------------------------------------------
f_show(string k) =>
    switch k
        "res"   => shRes
        "res0"  => shRes0
        "sup"   => shSup
        "sup0"  => shSup0
        "flip"  => shFlip
        "emh"   => shEM
        "eml"   => shEM
        "emb"   => shEMB
        "ivh"   => shIV
        "ivl"   => shIV
        "mpain" => shMP
        "gpos"  => shGp
        "gneg"  => shGn
        "opo"   => shOPG
        "opu"   => shOPG
        "opd"   => shOPG
        => true

f_col(string k) =>
    switch k
        "res"   => cRes
        "res0"  => cRes0
        "sup"   => cSup
        "sup0"  => cSup0
        "flip"  => cFlip
        "emh"   => cEM
        "eml"   => cEM
        "emb"   => cEMB
        "ivh"   => cIV
        "ivl"   => cIV
        "mpain" => cMP
        "gpos"  => cGp
        "gneg"  => cGn
        "opo"   => cOPG
        "opu"   => color.new(#EF5350, 55)
        "opd"   => color.new(#26A69A, 55)
        => color.new(#7A7A85, 30)

f_w(string k) =>
    switch k
        "res"   => wRes
        "res0"  => wRes0
        "sup"   => wSup
        "sup0"  => wSup0
        "flip"  => wFlip
        "emh"   => wEM
        "eml"   => wEM
        "emb"   => wEMB
        "ivh"   => wIV
        "ivl"   => wIV
        "mpain" => wMP
        "gpos"  => wGp
        "gneg"  => wGn
        "opo"   => wOPG
        "opu"   => wOPG
        "opd"   => wOPG
        => 1

f_ls(string s) =>
    s == DSH ? line.style_dashed : s == DOT ? line.style_dotted : line.style_solid

f_style(string k) =>
    string s = switch k
        "res"   => sRes
        "res0"  => sRes0
        "sup"   => sSup
        "sup0"  => sSup0
        "flip"  => sFlip
        "emh"   => sEM
        "eml"   => sEM
        "emb"   => sEMB
        "ivh"   => sIV
        "ivl"   => sIV
        "mpain" => sMP
        "gpos"  => sGp
        "gneg"  => sGn
        "opo"   => sOPG
        "opu"   => sOPG
        "opd"   => sOPG
        => SOL
    f_ls(s)

f_size(string s) =>
    s == "Small" ? size.small : s == "Normal" ? size.normal : size.tiny

// ---- alerts & proximity table --------------------------------------------------
const string GA = "Alerts & Table"
bool useAlerts = input.bool(true, "Alert on key level cross (walls / 0DTE / flip)", group = GA)
bool showTable = input.bool(true, "Proximity table", group = GA)

var array<float>  aP = array.new<float>()
var array<string> aT = array.new<string>()
var array<string> aK = array.new<string>()

if barstate.isfirst and str.length(src) > 0
    array<string> rows0 = str.split(src, ";")
    for r0 in rows0
        array<string> f0 = str.split(r0, ",")
        if array.size(f0) == 3
            float p0 = str.tonumber(array.get(f0, 0))
            if not na(p0)
                array.push(aP, p0)
                array.push(aT, array.get(f0, 1))
                array.push(aK, array.get(f0, 2))

f_isKey(string k) =>
    k == "res" or k == "sup" or k == "res0" or k == "sup0" or k == "flip"

if useAlerts and barstate.isconfirmed and array.size(aP) > 0
    for i = 0 to array.size(aP) - 1
        if f_isKey(array.get(aK, i))
            float lv = array.get(aP, i)
            bool crossUp = close[1] < lv and close >= lv
            bool crossDn = close[1] > lv and close <= lv
            if crossUp or crossDn
                alert("GEX level cross: " + array.get(aT, i) + " @ " + str.tostring(lv, format.mintick) + (crossUp ? " (up)" : " (down)"), alert.freq_once_per_bar)

var table tb = table.new(position.top_right, 3, 3, bgcolor = color.new(#131316, 15), border_width = 1, border_color = #222228)
if showTable and barstate.islast and array.size(aP) > 0
    float bestUp = na
    float bestDn = na
    string upT = ""
    string dnT = ""
    for i = 0 to array.size(aP) - 1
        float lv = array.get(aP, i)
        if lv >= close and (na(bestUp) or lv < bestUp)
            bestUp := lv
            upT := array.get(aT, i)
        if lv <= close and (na(bestDn) or lv > bestDn)
            bestDn := lv
            dnT := array.get(aT, i)
    table.cell(tb, 0, 0, "GEX " + f_market(),  text_color = #F0B90B, text_size = size.tiny)
    table.cell(tb, 1, 0, "level", text_color = #7A7A85, text_size = size.tiny)
    table.cell(tb, 2, 0, "dist",  text_color = #7A7A85, text_size = size.tiny)
    if not na(bestUp)
        table.cell(tb, 0, 1, "▲ " + upT, text_color = #26A69A, text_size = size.tiny)
        table.cell(tb, 1, 1, str.tostring(bestUp, format.mintick), text_color = #E8E6E1, text_size = size.tiny)
        table.cell(tb, 2, 1, "+" + str.tostring(bestUp - close, "#.#"), text_color = #7A7A85, text_size = size.tiny)
    if not na(bestDn)
        table.cell(tb, 0, 2, "▼ " + dnT, text_color = #EF5350, text_size = size.tiny)
        table.cell(tb, 1, 2, str.tostring(bestDn, format.mintick), text_color = #E8E6E1, text_size = size.tiny)
        table.cell(tb, 2, 2, str.tostring(bestDn - close, "#.#"), text_color = #7A7A85, text_size = size.tiny)

// ---- draw --------------------------------------------------------------------
var array<line>  lns = array.new<line>()
var array<label> lbs = array.new<label>()

if barstate.islast
    for l in lns
        line.delete(l)
    array.clear(lns)
    for lb in lbs
        label.delete(lb)
    array.clear(lbs)

    if str.length(src) > 0
        array<string> rows = str.split(src, ";")
        for r in rows
            array<string> f = str.split(r, ",")
            if array.size(f) == 3
                float  p    = str.tonumber(array.get(f, 0))
                string tag  = array.get(f, 1)
                string kind = array.get(f, 2)
                if not na(p) and f_show(kind)
                    color c = f_col(kind)
                    array.push(lns, line.new(bar_index - 1, p, bar_index, p, extend = extend.both, color = c, width = f_w(kind), style = f_style(kind)))
                    if gShowLbl
                        string txt = gPrice ? tag + "  " + str.tostring(p, format.mintick) : tag
                        array.push(lbs, label.new(bar_index + gOff, p, txt, style = label.style_label_left, color = color.new(color.black, 100), textcolor = c, size = f_size(gSize)))
